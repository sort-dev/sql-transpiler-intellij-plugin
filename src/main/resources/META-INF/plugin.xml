<idea-plugin>
    <id>dev.brikk.brikk-sql-intellij-plugin</id>
    <name>Brikk SQL</name>
    <vendor>Brikk</vendor>
    <description><![CDATA[
        Cross-dialect SQL transpilation inside DataGrip/IntelliJ, powered by brikk-sql
        (a full Kotlin port of sqlglot). Mark any SQL with <code>-- dialect: xyz</code> and
        execute it against the current engine through transpilation, or transpile any SQL
        between mysql, doris, trino, presto, duckdb, postgres, and clickhouse — with preview,
        in-place replacement, exact unsupported-node diagnostics, and native-parser validation.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Brikk SQL" displayType="BALLOON"/>

        <!-- BrikkSQL: the plugin-owned polyglot SQL dialect (.bsql files). Generic SQL
             parsing (lenient, ;-bounded statements) under our own language id, so
             per-segment enhancements can layer in over time. -->
        <fileType name="Brikk SQL"
                  implementationClass="dev.brikk.house.intellij.lang.BrikkSqlFileType"
                  fieldName="INSTANCE"
                  language="BrikkSQL"
                  extensions="bsql"/>
        <lang.parserDefinition language="BrikkSQL"
                               implementationClass="dev.brikk.house.intellij.lang.BrikkSqlParserDefinition"/>
        <lang.syntaxHighlighterFactory language="BrikkSQL"
                                       implementationClass="dev.brikk.house.intellij.lang.BrikkSqlSyntaxHighlighterFactory"/>
        <lang.commenter language="BrikkSQL"
                        implementationClass="dev.brikk.house.intellij.lang.BrikkSqlCommenter"/>

        <!-- Gutter icon on "dialect: xyz" line-comment markers. Registered on the base SQL
             language; LanguageExtension resolution covers every SQL dialect language. -->
        <codeInsight.lineMarkerProvider
                language="SQL"
                implementationClass="dev.brikk.house.intellij.DialectMarkerLineMarkerProvider"/>

        <!-- "Go Generic SQL" banner for vendor-dialect files containing foreign
             dialect-marker blocks (the polyglot scratch-file workflow). -->
        <editorNotificationProvider
                implementation="dev.brikk.house.intellij.MixedDialectNotificationProvider"/>

        <toolWindow id="Brikk SQL AST"
                    anchor="right"
                    secondary="true"
                    icon="AllIcons.Toolwindows.ToolWindowStructure"
                    factoryClass="dev.brikk.house.intellij.AstViewerToolWindowFactory"/>
    </extensions>

    <actions>
        <action id="BrikkSql.NewScratch"
                class="dev.brikk.house.intellij.lang.NewBrikkSqlScratchAction"
                text="New Brikk SQL Scratch"
                description="Creates a .bsql scratch file - the polyglot playground for dialect-marker blocks"
                icon="AllIcons.Nodes.DataTables">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <group id="BrikkSql.EditorMenu" text="Brikk SQL" popup="true">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <action id="BrikkSql.ExecuteViaTranspile"
                    class="dev.brikk.house.intellij.ExecuteViaTranspileAction"
                    text="Execute via Transpilation"
                    description="Transpiles the scope into the attached console's engine dialect, reviews the result (skipped when unchanged since last approval), and runs it"/>
            <action id="BrikkSql.TranspileTo"
                    class="dev.brikk.house.intellij.TranspileToAction"
                    text="Transpile To..."
                    description="Transpiles the selection (or dialect-marker block, or whole file) to a picked target dialect, with preview and diagnostics"/>
            <action id="BrikkSql.TranspileFrom"
                    class="dev.brikk.house.intellij.TranspileFromAction"
                    text="Transpile From..."
                    description="Picks the source dialect explicitly (overriding detection), then transpiles into the file's current dialect"/>
        </group>
    </actions>
</idea-plugin>
